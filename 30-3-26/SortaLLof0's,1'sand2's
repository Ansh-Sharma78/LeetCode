class Solution {
    public Node segregate(Node head) {
        // code here
        Node zero=new Node(-1);
        Node res=zero;
        Node one =new Node(-1);
        Node onehead=one;
        Node two=new Node(-1);
        Node twohead=two;
        
        Node temp=head;
        
        while(temp!=null){
            if(temp.data==0){
                zero.next=temp;
                zero=temp;
            }else if(temp.data==2){
                two.next=temp;
                two=temp;
            }else{
                one.next=temp;
                one=temp;
            }
            temp=temp.next;
        }
        if(onehead.next!=null){
            zero.next=onehead.next;
        }else{
            zero.next=twohead.next;
        }
        if(twohead.next!=null){
            one.next=twohead.next;
        }else{
            one.next=null;
        }
        two.next=null;
        
        return res.next;
        
    }
}